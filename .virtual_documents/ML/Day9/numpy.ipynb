# assigning all values to zero
array1 = np.zeros((2,3), dtype= "int64")
print(array1, array1.shape, array1.dtype)


# without datatype it becomes float
array2 = np.ones((3,4))
print(array2, array2.shape, array2.dtype)


# assiging desired value
array3 = np.full((3,5), 100)
print(array3, array3.shape, array3.dtype)


array4 = np.eye(3)
print(array4, array4.shape, array4.dtype)


arr5 = np.arange(8,)
print(arr5)


arr6 = np.arange(0, 11, 2)
print(arr6)


arr7 = np.linspace(1, 100, 5)
print(arr7)


arr8 = np.arange(1,11)
print(arr8)
print("size = " , arr8.size)
print("data type = ", arr8.dtype)


#typeConversion in numpy
float_arr = arr8.astype(np.float64)
print(float_arr)
print("data_type = ", float_arr.dtype)





